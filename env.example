# SignaMentis Trading System - Environment Variables Example
# Author: SignaMentis Team
# Version: 2.0.0
# 
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
SYSTEM_NAME=SignaMentis
SYSTEM_VERSION=2.0.0
SYSTEM_ENVIRONMENT=production
SYSTEM_TIMEZONE=UTC
SYSTEM_DEBUG=false
SYSTEM_LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=signa_mentis
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/signa_mentis
MONGODB_MAX_CONNECTIONS=100
MONGODB_CONNECTION_TIMEOUT=30000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# TRADING & EXECUTION
# =============================================================================
# MetaTrader 5
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_TIMEOUT=60000
MT5_DEVIATION=10
MT5_MAX_RETRIES=3
MT5_RETRY_DELAY=1.0

# MetaAPI Cloud
METAAPI_ACCOUNT_ID=
METAAPI_TOKEN=
METAAPI_SERVER=demo
METAAPI_MAX_ATTEMPTS=5
METAAPI_DELAY=1000
METAAPI_BACKOFF_MULTIPLIER=2.0

# =============================================================================
# NEWS & SENTIMENT ANALYSIS
# =============================================================================
# GDELT
GDELT_API_KEY=
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
GDELT_RATE_LIMIT=1000

# Trading Economics
TRADINGECONOMICS_API_KEY=
TRADINGECONOMICS_BASE_URL=https://api.tradingeconomics.com
TRADINGECONOMICS_RATE_LIMIT=1000

# NewsAPI
NEWSAPI_API_KEY=
NEWSAPI_BASE_URL=https://newsapi.org/v2
NEWSAPI_RATE_LIMIT=1000

# GNews
GNEWS_API_KEY=
GNEWS_BASE_URL=https://gnews.io/api/v4
GNEWS_RATE_LIMIT=1000

# FinBERT Model
FINBERT_MODEL_PATH=models/finbert
FINBERT_MODEL_NAME=ProsusAI/finbert
FINBERT_UPDATE_INTERVAL=300

# =============================================================================
# MESSAGING & COMMUNICATION
# =============================================================================
# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUAL_HOST=/
RABBITMQ_MAX_CONNECTIONS=10

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=True

# =============================================================================
# MONITORING & TELEMETRY
# =============================================================================
# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_INTERVAL=60
PROMETHEUS_HEALTH_CHECK_INTERVAL=30

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USERNAME=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_API_KEY=

# =============================================================================
# MLOPS & EXPERIMENT TRACKING
# =============================================================================
# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_REGISTRY_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=SignaMentis_Trading
MLFLOW_ARTIFACT_STORE=./mlruns

# DVC
DVC_REMOTE=origin
DVC_REMOTE_URL=
DVC_REMOTE_USERNAME=
DVC_REMOTE_PASSWORD=

# Feast Feature Store
FEAST_REPO_PATH=mlops/feast/feature_repo
FEAST_REGISTRY_PATH=mlops/feast/feature_repo/registry.db
FEAST_ONLINE_STORE_TYPE=redis
FEAST_ONLINE_STORE_CONNECTION_STRING=redis://localhost:6379/0

# Optuna
OPTUNA_STORAGE=sqlite:///optuna.db
OPTUNA_STUDY_NAME=SignaMentis_Optimization

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRY_HOURS=24
JWT_ALGORITHM=HS256

# API Authentication
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=your-api-key-here
API_RATE_LIMIT_REQUESTS_PER_MINUTE=100
API_RATE_LIMIT_BURST_SIZE=20

# Encryption
ENCRYPTION_ENABLED=true
ENCRYPTION_ALGORITHM=AES-256-GCM
ENCRYPTION_KEY_ROTATION_DAYS=30
ENCRYPTION_SECRET_KEY=your-32-byte-encryption-key-here

# Vault (HashiCorp)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_NAMESPACE=
VAULT_MOUNT_PATH=secret

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Email (SMTP)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Slack
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=
SLACK_ENABLED=false

# Discord
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false

# =============================================================================
# FINANCIAL DATA PROVIDERS
# =============================================================================
# Alpha Vantage
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_RATE_LIMIT=5

# Quandl
QUANDL_API_KEY=
QUANDL_BASE_URL=https://www.quandl.com/api/v3

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred

# Finnhub
FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# =============================================================================
# PERFORMANCE & OPTIMIZATION
# =============================================================================
# GPU Configuration
USE_GPU=true
CUDA_VISIBLE_DEVICES=0
TORCH_NUM_THREADS=4

# Memory & Processing
MEMORY_LIMIT=8GB
MAX_CONCURRENT_TASKS=100
TASK_TIMEOUT=30

# Caching
CACHE_ENABLED=true
CACHE_BACKEND=redis
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# =============================================================================
# DEVELOPMENT & TESTING
# =============================================================================
# Testing
TEST_ENVIRONMENT=development
TEST_DATABASE=signa_mentis_test
TEST_LOG_LEVEL=DEBUG
TEST_COVERAGE=true
TEST_COVERAGE_HTML_DIR=coverage_html

# Development
DEV_MODE=false
DEV_DEBUG=true
DEV_RELOAD=true
DEV_HOST=0.0.0.0
DEV_PORT=8000

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=structured
LOG_CONSOLE=true
LOG_FILE=true
LOG_JSON=false
LOG_NETWORK=false

# Log Rotation
LOG_MAX_FILE_SIZE=10MB
LOG_BACKUP_COUNT=5
LOG_COMPRESS=true

# Log Categories
LOG_CATEGORY_SYSTEM=INFO
LOG_CATEGORY_TRADING=INFO
LOG_CATEGORY_AI_MODELS=DEBUG
LOG_CATEGORY_RISK_MANAGEMENT=INFO
LOG_CATEGORY_EXECUTION=INFO
LOG_CATEGORY_PERFORMANCE=INFO
LOG_CATEGORY_ALERTS=WARNING
LOG_CATEGORY_API=INFO
LOG_CATEGORY_DATABASE=WARNING
LOG_CATEGORY_NETWORK=WARNING

# =============================================================================
# NETWORK & SECURITY
# =============================================================================
# Network Security
ALLOWED_IPS=127.0.0.1,::1
SSL_ENABLED=true
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CA_PATH=

# CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE
CORS_ALLOWED_HEADERS=*

# =============================================================================
# BACKTESTING & VALIDATION
# =============================================================================
# Cross-Validation
CV_METHOD=purged_kfold
CV_N_SPLITS=5
CV_PURGE=10
CV_EMBARGO=5

# Performance Metrics
PERFORMANCE_METRICS=total_return,sharpe_ratio,max_drawdown,win_rate,profit_factor,calmar_ratio

# =============================================================================
# FEATURE ENGINEERING
# =============================================================================
# Technical Indicators
FEATURE_TECHNICAL_INDICATORS=true
FEATURE_MARKET_STRUCTURE=true
FEATURE_TIME_FEATURES=true
FEATURE_VOLATILITY_FEATURES=true
FEATURE_SENTIMENT_FEATURES=true

# Feature Store
FEATURE_STORE_ENABLED=true
FEATURE_STORE_BACKEND=feast
FEATURE_STORE_REPO_PATH=mlops/feast/feature_repo

# =============================================================================
# MODEL TRAINING & DEPLOYMENT
# =============================================================================
# Training
TRAINING_BATCH_SIZE=32
TRAINING_SEQUENCE_LENGTH=100
TRAINING_VALIDATION_SPLIT=0.2
TRAINING_EARLY_STOPPING_PATIENCE=10
TRAINING_LEARNING_RATE=0.001
TRAINING_MAX_EPOCHS=100

# Model Registry
MODEL_REGISTRY_ENABLED=true
MODEL_REGISTRY_BACKEND=mlflow
MODEL_VERSIONING=true
MODEL_ROLLBACK_ENABLED=true

# =============================================================================
# ALERTS & NOTIFICATIONS
# =============================================================================
# Alert Thresholds
ALERT_RISK_EXPOSURE=0.8
ALERT_DRAWDOWN=0.05
ALERT_CONSECUTIVE_LOSSES=3
ALERT_LOW_CONFIDENCE=0.6

# Alert Channels
ALERT_EMAIL_ENABLED=false
ALERT_TELEGRAM_ENABLED=false
ALERT_SLACK_ENABLED=false
ALERT_DISCORD_ENABLED=false
ALERT_WEBHOOK_ENABLED=false

# =============================================================================
# DOCKER & CONTAINERIZATION
# =============================================================================
# Docker
DOCKER_ENABLED=false
DOCKER_COMPOSE_FILE=docker-compose.yml
DOCKER_NETWORK=signamentis_network
DOCKER_VOLUME_PREFIX=signamentis

# =============================================================================
# CI/CD & DEPLOYMENT
# =============================================================================
# GitHub Actions
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_WORKFLOW_ID=

# Deployment
DEPLOYMENT_ENVIRONMENT=production
DEPLOYMENT_VERSION=
DEPLOYMENT_ROLLBACK_ENABLED=true
DEPLOYMENT_HEALTH_CHECK_URL=http://localhost:8000/health

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Health Checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Metrics
METRICS_ENABLED=true
METRICS_INTERVAL=60
METRICS_EXPORT_ENABLED=true
METRICS_EXPORT_PORT=9090

# Tracing
TRACING_ENABLED=false
TRACING_BACKEND=jaeger
TRACING_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
BACKUP_ENCRYPTION=true

# Recovery
RECOVERY_ENABLED=true
RECOVERY_POINT_OBJECTIVE=3600  # 1 hour
RECOVERY_TIME_OBJECTIVE=7200   # 2 hours

# =============================================================================
# COMPLIANCE & AUDITING
# =============================================================================
# Audit Logging
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
AUDIT_LOG_ENCRYPTION=true

# Compliance
COMPLIANCE_GDPR_ENABLED=true
COMPLIANCE_SOX_ENABLED=false
COMPLIANCE_PCI_ENABLED=false

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================
# Add any custom environment variables below
CUSTOM_FEATURE_FLAG_1=false
CUSTOM_FEATURE_FLAG_2=false
CUSTOM_API_ENDPOINT=
CUSTOM_TIMEOUT=30

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file to version control
# 2. Keep your API keys and secrets secure
# 3. Use different values for development, staging, and production
# 4. Regularly rotate sensitive credentials
# 5. Monitor environment variable usage and security
